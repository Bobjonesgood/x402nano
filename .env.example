PORT=4021

# sandbox keeps the local simulated signer active.
# facilitator expects the client to send a real x402 payment payload in X-PAYMENT.
X402_PAYMENT_MODE=sandbox

# Sandbox-only deterministic signing secret.
FACILITATOR_SECRET=sandbox-facilitator-secret

# Seller/payment metadata.
# SELLER_ADDRESS is preferred. PARTNER_SELLER_ADDRESS is accepted as a fallback.
SELLER_ADDRESS=0xSellerPremiumLeadDesk
PARTNER_SELLER_ADDRESS=
BUYER_ADDRESS=0xAutonomousAgentWallet
PRICE_USDC=0.05
X402_NETWORK=eip155:84532
X402_ASSET=USDC

# Paid product data boundary. Mainnet requires a production pack.
LEAD_PACK_MODE=demo
PREMIUM_LEAD_PACK_JSON=
LEAD_PACK_FILE=data/production-lead-pack.runtime.json
LEAD_PACK_FILE_REFRESH_MS=30000
LEAD_PACK_ADMIN_TOKEN=

# Autonomous public-source lead engine. Use explicit public URLs you are allowed to crawl.
LEAD_ENGINE_MARKET=
LEAD_ENGINE_MARKET_FILE=data/lead-engine-markets.json
LEAD_ENGINE_SOURCE_URLS=
LEAD_ENGINE_SOURCE_MODE=manual
LEAD_ENGINE_MAX_PAGES=20
LEAD_ENGINE_PACK_LIMIT=25
LEAD_ENGINE_MIN_CONFIDENCE=70
LEAD_ENGINE_INTERVAL_MS=21600000
LEAD_ENGINE_RESPECT_ROBOTS=true
LEAD_ENGINE_FOLLOW_LINKS=true
LEAD_ENGINE_MERGE_EXISTING=true

# Optional OpenAI-compatible free-credit inference endpoint.
# Example shape: https://provider.example/v1/chat/completions
AI_INFERENCE_URL=
AI_API_KEY=
AI_MODEL=

# Controlled Base mainnet buyer proof. Keep these local and use a tiny-funded buyer wallet.
# MAINNET_BUYER_PRIVATE_KEY=
# BASE_MAINNET_RPC_URL=
# MAINNET_PAYMENT_ACK=PAY_REAL_0.05_USDC
# MAINNET_MAX_USDC=0.05
# MAINNET_EXPECTED_SELLER_ADDRESS=

# Facilitator mode.
# Example from x402 docs for production facilitators:
# X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
X402_FACILITATOR_URL=
# Legacy bearer token slot for facilitators that require one static token.
X402_FACILITATOR_API_KEY=
# CDP production facilitator Secret API Key credentials.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Real buyer agent testnet wallet. Use a funded Base Sepolia test wallet only.
BUYER_PRIVATE_KEY=
BASE_SEPOLIA_RPC_URL=

# LeadNestAI handoff integration.
# Keep disabled until local handoff tests pass. Set LEAD_HANDOFF_ON_UNLOCK=true
# only when every paid unlock should stream its leads into LeadNestAI.
LEAD_HANDOFF_ENABLED=false
LEAD_HANDOFF_ON_UNLOCK=false
LEADNESTAI_API_URL=http://127.0.0.1:5055
LEADNESTAI_INGEST_SECRET=local-test-secret
LEADNESTAI_SOURCE_ID=x402nano
