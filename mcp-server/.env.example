# The production API origin is intentionally restricted to this exact HTTPS host.
X402NANO_API_ORIGIN=https://x402nano.onrender.com

# Paid tools remain disabled unless this exact acknowledgement is present.
X402NANO_PAYMENT_ACK=PREFLIGHT_ONLY

# Use a dedicated, minimally funded Base buyer wallet. Never commit this value.
X402NANO_BUYER_PRIVATE_KEY=

# A paid brief or delta must be exactly 0.05 USDC and may never exceed this cap.
X402NANO_MAX_PAYMENT_USDC=0.05

# Optional Base RPC override used only by the local buyer.
X402NANO_BASE_RPC_URL=https://mainnet.base.org

# Allows for an occasional Render cold start. Range: 5000-120000 milliseconds.
X402NANO_REQUEST_TIMEOUT_MS=60000
