{
  "name": "x402nano",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/index.js",
    "render:start": "node server/index.js",
    "test": "node --test server/webhook-alerts.test.js server/webhook-alerts.integration.test.js",
    "agent:mainnet": "node scripts/mainnet-x402-buyer.js",
    "wallet:mainnet:create": "node scripts/create-mainnet-buyer-wallet.js"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.50.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@x402/core": "^2.12.0",
    "@x402/evm": "^2.12.0",
    "@x402/extensions": "^2.12.0",
    "@x402/fetch": "^2.12.0",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^10.0.3",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "viem": "^2.49.3",
    "vite": "^6.0.0"
  }
}
